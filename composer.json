{
    "name": "survos/command-schema",
    "type": "library",
    "description": "Reflection-based metadata schema for Symfony Console commands. Consumed by TUI, web, and MCP runners that need a typed view of every command's arguments, options, and prompts.",
    "license": "MIT",
    "authors": [
        {
            "name": "Tac Tacelosky",
            "email": "tacman@gmail.com"
        }
    ],
    "require": {
        "php": "^8.4",
        "symfony/console": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.5",
        "phpstan/phpstan": "^2.0",
        "symplify/easy-coding-standard": "^13.0"
    },
    "suggest": {
        "symfony/tui": "Required to use the bundled `commands` TUI runner (vendor/bin/commands)."
    },
    "autoload": {
        "psr-4": {
            "Survos\\CommandSchema\\": "src/"
        }
    },
    "bin": ["bin/commands"],
    "autoload-dev": {
        "psr-4": {
            "Survos\\CommandSchema\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
